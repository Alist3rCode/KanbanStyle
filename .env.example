# Copy to .env and fill in before running `docker compose up`.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string
# Encrypts secrets at rest (e.g. the Jira token) — keep this stable across
# restarts/redeploys, or previously saved secrets become unreadable.
ENCRYPTION_KEY=replace-with-another-long-random-string
